---
layout: layouts/base.njk
pagination:
  data: site.categories
  size: 1
  alias: cat
permalink: "/{{ cat.slug }}/"
eleventyComputed:
  title: "{{ cat.label }}"
---
<section class="archive band--{{ cat.slug }}">
  <header class="archive-head">
    <h1 class="band-title">{{ cat.label }}</h1>
    <p class="band-blurb">{{ cat.blurb }}</p>
  </header>
  <div class="grid">
    {% for post in collections[cat.slug] %}
      {% include "card.njk" %}
    {% else %}
      <p class="empty">Nothing here yet — the first {{ cat.label | lower }} post is coming.</p>
    {% endfor %}
  </div>
</section>
