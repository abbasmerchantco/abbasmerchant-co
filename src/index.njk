---
title: Abbas Merchant
description: A public record of everything I read, watch, think about, and experience.
layout: layouts/base.njk
---

<div class="hero">
  <div class="hero-top">
    <div class="hero-top-left">
      <div class="avatar">AM</div>
      <div class="hero-greeting">
        <strong>Abbas Merchant</strong><br/>
        Operations & Program Management<br/>
        <a href="/about/">More about me →</a>
      </div>
    </div>
    <div class="hero-stat">
      <div class="stat-num">{{ collections.publishedPosts | length }}</div>
      <div class="stat-lbl">Posts</div>
    </div>
  </div>
  <h1>A public record of everything I read, watch, think about, and experience.</h1>
  <p class="hero-desc">Welcome to my blog — essays on leadership, operations, technology, and life. Updated regularly.</p>
</div>

<div class="feed-wrap">
  <div class="feed">
    {% set categories = [
      { value: "musings", label: "✍️ Musings" },
      { value: "learnings", label: "💡 Learnings" },
      { value: "movies", label: "🎬 Movies" },
      { value: "books", label: "📚 Books" },
      { value: "photos", label: "📷 Photos" },
      { value: "travel", label: "✈️ Travel" },
      { value: "mba", label: "🎓 MBA" }
    ] %}

    {% for post in collections.publishedPosts %}
      {% set cat = post.data.category %}
      {% set catLabel = categories | selectattr("value", "eq", cat) | first %}
      <a href="{{ post.url }}" class="card {% if post.data.featured %}featured{% endif %} cat-{{ cat }} {% if post.data.coverImage %}has-img{% endif %}">
        {% if post.data.coverImage %}
          <img src="{{ post.data.coverImage }}" alt="{{ post.data.title }}" class="card-img" />
        {% else %}
          <div class="card-fallback">{{ catLabel.label.split(' ')[0] }}</div>
          <div class="accent"></div>
        {% endif %}
        <div class="card-body">
          <div class="cat-tag">{{ catLabel.label }}</div>
          <h2>{{ post.data.title }}</h2>
          {% if post.data.excerpt %}<p>{{ post.data.excerpt }}</p>{% endif %}
          <div class="card-meta">
            <span>{{ post.data.date | readableDate }}</span>
            <span class="read-link">{{ post.data.readTime }} →</span>
          </div>
        </div>
      </a>
    {% endfor %}

    {% if collections.publishedPosts.length === 0 %}
      <div class="empty">No posts yet. Check back soon.</div>
    {% endif %}
  </div>
</div>
