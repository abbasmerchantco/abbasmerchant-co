---
title: Abbas Merchant
description: A public record of everything I read, watch, think about, and experience.
layout: layouts/base.njk
---

<div class="hero">
  <div class="hero-content">
    <h1>Abbas Merchant</h1>
    <p>A public record of everything I read, watch, think about, and experience.</p>
    <a href="/about/" class="hero-link">Who's Abbas? →</a>
  </div>
</div>

{% for category in categories %}
  {% set postsInCategory = collections.postsByCategory[category.value] | default([]) %}
  {% if postsInCategory.length > 0 %}
    <section class="category-band" data-category="{{ category.value }}">
      <h2 class="category-title">{{ category.label }}</h2>
      <div class="posts-scroll">
        {% for post in postsInCategory %}
          <article class="post-card">
            <div class="card-cover">
              {% if post.data.coverImage %}
                <img src="{{ post.data.coverImage }}" alt="{{ post.data.title }}" loading="lazy" />
              {% else %}
                <div class="card-emoji">{{ category.emoji }}</div>
              {% endif %}
            </div>
            <div class="card-content">
              <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
              {% if post.data.excerpt %}
                <p class="excerpt">{{ post.data.excerpt }}</p>
              {% endif %}
              <div class="card-meta">
                <span class="date">{{ post.data.date | readableDate }}</span>
                <span class="readTime">{{ post.data.readTime }}</span>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
    </section>
  {% endif %}
{% endfor %}
