---
title: Abbas Merchant
description: A public record of everything I read, watch, think about, and experience.
layout: layouts/base.njk
---

<div class="hero">
  <h1>Abbas Merchant</h1>
  <p>Operations & Program Management. Currently at <strong>Greater Western Water</strong>.</p>
  <p>Exploring leadership, systems thinking, and how to build things that matter.</p>
</div>

{% set categories = [
  { value: "musings", label: "✍️ Musings", emoji: "✍️" },
  { value: "learnings", label: "💡 Learnings", emoji: "💡" },
  { value: "movies", label: "🎬 Movies", emoji: "🎬" },
  { value: "books", label: "📚 Books", emoji: "📚" },
  { value: "photos", label: "📷 Photos", emoji: "📷" },
  { value: "travel", label: "✈️ Travel", emoji: "✈️" },
  { value: "mba", label: "🎓 MBA", emoji: "🎓" }
] %}

<div class="content">
  {% for category in categories %}
    {% set postsInCategory = collections.postsByCategory[category.value] | default([]) %}
    {% if postsInCategory.length > 0 %}
      <section class="category-section" data-category="{{ category.value }}">
        <h2 class="category-title">{{ category.label }}</h2>
        <div class="posts-grid">
          {% for post in postsInCategory %}
            <article class="post-card">
              <div class="card-cover">
                {% if post.data.coverImage %}
                  <img src="{{ post.data.coverImage }}" alt="{{ post.data.title }}" loading="lazy" />
                {% else %}
                  <div class="card-emoji">{{ category.emoji }}</div>
                {% endif %}
              </div>
              <div class="card-body">
                <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
                {% if post.data.excerpt %}
                  <p class="excerpt">{{ post.data.excerpt }}</p>
                {% endif %}
                <div class="card-meta">
                  <span class="date">{{ post.data.date | readableDate }}</span>
                  <span class="readTime">{{ post.data.readTime }}</span>
                </div>
              </div>
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}
  {% endfor %}
</div>
