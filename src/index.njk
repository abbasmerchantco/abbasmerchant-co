---
layout: layouts/base.njk
title: Abbas Merchant
description: A public record of everything I read, watch, think about, and experience.
permalink: /
---

<!-- HERO -->
<section class="hero">
  <div class="hero-top">
    <div class="hero-top-left">
      <div class="avatar">AM</div>
      <div class="hero-greeting">
        <strong>Hey, I'm Abbas.</strong> Melbourne-based, curious by default.<br>
        <a href="/about/">Who's Abbas? →</a>
      </div>
    </div>
    <div class="hero-stat">
      <div class="stat-num" id="post-count">0</div>
      <div class="stat-lbl">Published</div>
    </div>
  </div>
  <h1>Thoughts, films<br>&amp; <em>far-flung</em> places.</h1>
  <p class="hero-desc">A public record of everything I read, watch, think about, and experience — if it crossed my mind or my path, it's probably here.</p>
</section>

<!-- FILTERS -->
<div class="filters-wrap">
  <div class="filters">
    <button class="f-btn on" onclick="setFilter('all', this)">All</button>
    <button class="f-btn" onclick="setFilter('musings', this)">✍ Musings</button>
    <button class="f-btn" onclick="setFilter('learnings', this)">💡 Learnings</button>
    <button class="f-btn" onclick="setFilter('movies', this)">🎬 Movies</button>
    <button class="f-btn" onclick="setFilter('books', this)">📚 Books</button>
    <button class="f-btn" onclick="setFilter('photos', this)">📷 Photos</button>
    <button class="f-btn" onclick="setFilter('travel', this)">✈ Travel</button>
    <button class="f-btn" onclick="setFilter('mba', this)">🎓 MBA</button>
  </div>
</div>

<!-- FEED -->
<div class="feed-wrap">
  <div class="feed">
    {%- for post in collections.publishedPosts -%}
    {% set catEmoji = CAT_EMOJI[post.data.category] or '📝' %}
    {% set featured = post.data.featured %}
    {% set hasImg = post.data.coverImage %}
    <article class="card{% if featured %} featured{% endif %}{% if hasImg %} has-img{% endif %} cat-{{ post.data.category }}"
             data-post="true"
             data-category="{{ post.data.category }}"
             data-title="{{ post.data.title }}"
             data-excerpt="{{ post.data.excerpt }}"
             onclick="window.location.href='{{ post.url }}'">

      {% if featured %}<div class="featured-badge">★ Featured</div>{% endif %}

      {% if hasImg -%}
        <img class="card-img" src="{{ post.data.coverImage }}" alt="" loading="lazy"
             style="width:100%;aspect-ratio:{% if featured %}21/9{% else %}16/9{% endif %};object-fit:cover;display:block;" />
      {%- else -%}
        <div class="card-fallback">{{ catEmoji }}</div>
      {%- endif %}

      <div class="card-body">
        <div class="accent"></div>
        <div class="cat-tag">{{ CAT_LABELS[post.data.category] or post.data.category }}</div>
        <h2>{{ post.data.title }}</h2>
        <p>{{ post.data.excerpt }}</p>
        <div class="card-meta">
          <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }} · {{ post.data.readTime or '5 min' }} read</time>
          <span class="read-link">Read →</span>
        </div>
      </div>
    </article>
    {%- endfor %}
  </div>
</div>

