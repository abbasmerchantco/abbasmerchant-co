---
title: Abbas Merchant
layout: layouts/base.njk
---
{% set catMeta = {
  musings:   { label: "✍️ Musings",   emoji: "✍️" },
  learnings: { label: "💡 Learnings", emoji: "💡" },
  movies:    { label: "🎬 Movies",    emoji: "🎬" },
  books:     { label: "📚 Books",     emoji: "📚" },
  photos:    { label: "📷 Photos",    emoji: "📷" },
  travel:    { label: "✈️ Travel",    emoji: "✈️" },
  mba:       { label: "🎓 MBA",       emoji: "🎓" }
} %}

<div class="hero">
  <div class="hero-top">
    <div class="hero-top-left">
      <div class="avatar">AM</div>
      <div class="hero-greeting">
        <strong>Abbas Merchant</strong><br/>
        Operations & Program Management, Greater Western Water<br/>
        <a href="/about/">More about me →</a>
      </div>
    </div>
    <div class="hero-stat">
      <div class="stat-num">{{ collections.publishedPosts.length }}</div>
      <div class="stat-lbl">Posts</div>
    </div>
  </div>
  <h1>A public record of everything I read, watch, think about, and experience.</h1>
  <p class="hero-desc">Essays on leadership, systems thinking, books, travel, and the MBA journey.</p>
</div>

<div class="filters-wrap">
  <div class="filters">
    <button class="f-btn on" data-filter="all">All</button>
    {% for key, meta in catMeta %}
      <button class="f-btn" data-filter="{{ key }}">{{ meta.label }}</button>
    {% endfor %}
  </div>
</div>

<div class="feed-wrap">
  <div class="feed" id="feed">
    {% for post in collections.publishedPosts %}
      {% set meta = catMeta[post.data.category] %}
      <a href="{{ post.url }}" class="card cat-{{ post.data.category }} {% if post.data.coverImage %}has-img{% endif %} {% if post.data.featured %}featured{% endif %}" data-category="{{ post.data.category }}">
        {% if post.data.coverImage %}
          <img src="{{ post.data.coverImage }}" class="card-img" alt="{{ post.data.title }}" loading="lazy" />
        {% else %}
          <div class="card-fallback">{{ meta.emoji }}</div>
        {% endif %}
        <div class="card-body">
          <div class="accent"></div>
          <div class="cat-tag">{{ meta.label }}</div>
          <h2>{{ post.data.title }}</h2>
          {% if post.data.excerpt %}<p>{{ post.data.excerpt }}</p>{% endif %}
          <div class="card-meta">
            <span>{{ post.data.date | readableDate }}</span>
            <span class="read-link">Read →</span>
          </div>
        </div>
      </a>
    {% endfor %}
    {% if collections.publishedPosts.length === 0 %}
      <div class="empty">No posts yet.</div>
    {% endif %}
  </div>
</div>

<script>
  document.querySelectorAll('.f-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.f-btn').forEach(b => b.classList.remove('on'));
      btn.classList.add('on');
      const filter = btn.dataset.filter;
      document.querySelectorAll('#feed .card').forEach(card => {
        card.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none';
      });
    });
  });
</script>
