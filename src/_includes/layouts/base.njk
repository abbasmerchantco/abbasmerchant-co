<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ excerpt or site.tagline }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,650;0,9..144,900;1,9..144,500&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='90'>☀️</text></svg>">
</head>
<body>
  <header class="site-header">
    <a class="wordmark" href="/">Abbas<span class="wordmark-dot">.</span></a>
    <nav class="site-nav" aria-label="Categories">
      {% for cat in site.categories %}
      <a href="/{{ cat.slug }}/">{{ cat.label }}</a>
      {% endfor %}
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p class="footer-big">Thanks for reading.</p>
    <p class="footer-small">© {% year %} Abbas Merchant · Melbourne, Australia · written honestly, published imperfectly.</p>
  </footer>
</body>
</html>
